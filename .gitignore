# Top-level catch-all. Per-subproject .gitignore files (TradingBot/.gitignore,
# Trade_Perf/.gitignore) carry the project-specific rules.

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
.Python

# Local secrets (defensive)
*.env
*.key
*.pem
secrets/

# Helm runtime settings live at ~/.helm/ (outside this repo by design).
# settings.json holds only non-sensitive config; credentials.json holds the
# AI provider API keys + broker account IDs and must NEVER be committed.
# Belt-and-suspenders: block any in-tree copies too.
.helm/
**/.helm/
helm-settings.json
helm-settings*.json
credentials.json
**/credentials.json
*.api-keys

# Build artifacts
dist/
build/
*.egg-info/

# Node
node_modules/

# Local backups
backups/
*.zip
*.tar
*.tar.gz

# Branding / business docs -- keep out of the (public) repo
Documentation/
